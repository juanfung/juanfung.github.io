@article{fung2020predictive,
  author = {Juan F Fung and Siamak Sattar and David T Butry and Steven L McCabe},
  title ={A predictive modeling approach to estimating seismic retrofit costs},
  journal = {Earthquake Spectra},
  volume = {36},
  number = {2},
  pages = {579-598},
  year = {2020},
  doi = {10.1177/8755293019891716},
  url = {\url{https://doi.org/10.1177/8755293019891716}},
  eprint = {https://doi.org/10.1177/8755293019891716},
  abstract = { This article presents a methodology for estimating
                  seismic retrofit costs from historical data. In
                  particular, historical retrofit-cost data from
                  Federal Emergency Management Agency (FEMA) 156 is
                  used to build a generalized linear model (GLM) to
                  predict retrofit costs as a function of building
                  characteristics. While not as accurate as an
                  engineering professional’s estimate, this
                  methodology is easy to apply to generate quick
                  estimates and is especially useful for decision
                  makers with large building portfolios. Moreover, the
                  predictive modeling approach provides a measure of
                  uncertainty in terms of prediction error. The
                  article uses prediction error to compare different
                  modeling choices, including the choice of
                  distribution for costs. Finally, the proposed
                  retrofit-cost model is implemented to estimate the
                  cost to retrofit a portfolio of federal
                  buildings. The application illustrates how the
                  choice of distribution affects cost estimates.},
  pdf={eqs-1.pdf},
  selected={true}
}

